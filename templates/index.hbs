<!DOCTYPE html>
<html lang="zh-Hant">
<head>
{{> head}}
</head>
<body class="page-home">
<a class="skip-link" href="#main">跳至主內容</a>
{{> header}}

<main id="main">

  <!-- Section 1: Hero -->
  <section class="hero" aria-labelledby="hero-title">
    <div class="container hero__content">
      <h1 class="hero__title" id="hero-title">
        <span>{{hero.line1}}</span>
        <span>{{hero.line2}}</span>
        <span>{{hero.line3}}</span>
      </h1>
      <a href="{{hero.ctaLink}}" class="btn btn--light hero__cta">
        {{hero.ctaText}}
        <span class="btn__arrow" aria-hidden="true">→</span>
      </a>
    </div>
    <span class="hero__scroll" aria-hidden="true">Scroll</span>
  </section>

  <!-- Section 2: AEO definition -->
  <section class="section section--sm reveal">
    <div class="container">
      <p class="aeo-text">{{aeoIntro}}</p>
    </div>
  </section>

  <!-- Section 3: Poetic intro -->
  <section class="section reveal">
    <div class="container container--narrow">
      <div class="poetic-text poetic-text--lg">
        {{{poeticLines poeticIntro}}}
      </div>
    </div>
  </section>

  <!-- Atmospheric band: sunrise -->
  <div class="atmospheric-band atmospheric-band--sunrise reveal reveal--atmospheric" aria-hidden="true"></div>

  <!-- Section 4: 你是否曾經 -->
  <section class="section section--ivory-light">
    <div class="container container--narrow">
      <div class="reveal">
        <span class="eyebrow">— 共鳴 —</span>
        <h2 class="section-title-cn" style="margin-top: var(--space-sm);">{{checklistTitle}}</h2>
      </div>
      <ul class="checklist reveal reveal--delay-1">
        {{#each checklist}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
      <div class="poetic-text home-checklist-footer reveal reveal--delay-2">
        {{{poeticLines checklistFooter}}}
      </div>
    </div>
  </section>

  <!-- Section 5: 在量子催眠中 -->
  <section class="section reveal">
    <div class="container container--narrow">
      <div class="poetic-text poetic-text--lg">
        {{{poeticLines midPoetic}}}
      </div>
      <ul class="experience-list">
        {{#each experiences}}
          <li>{{this}}</li>
        {{/each}}
      </ul>
      <div class="poetic-text" style="margin-top: var(--space-lg); font-style: italic; color: var(--smoked-mineral);">
        {{{poeticLines experienceFooter}}}
      </div>
    </div>
  </section>

  <!-- Section 6: Core statement (dark band) -->
  <section class="statement" aria-labelledby="core-statement">
    <div class="container">
      <h2 class="statement__text" id="core-statement">
        {{#each coreStatement}}
          <span>{{this}}</span>
        {{/each}}
      </h2>
    </div>
  </section>

  <!-- Section 7: Closing CTA -->
  <section class="section reveal">
    <div class="container container--narrow closing-cta">
      <div class="poetic-text">
        {{{poeticLines closingCta}}}
      </div>
      <a href="/contact.html" class="btn btn--primary">
        預約諮詢
        <span class="btn__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

</main>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "name": "{{global.brandName}}",
  "alternateName": "{{global.brandNameEn}}",
  "description": "{{seo.description}}",
  "url": "{{global.siteUrl}}",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "台北市",
    "addressRegion": "Taipei",
    "addressCountry": "TW"
  },
  "founder": {
    "@type": "Person",
    "name": "{{global.practitionerName}}",
    "jobTitle": "QHHT 量子催眠高階認證催眠師",
    "description": "持有美國 QHHT 高階執照與 NGH 古典催眠教授執照，{{global.practiceSince}} 年起執業"
  },
  "serviceType": ["量子催眠", "QHHT", "Quantum Healing Hypnosis Technique"],
  "areaServed": "台北",
  "availableChannel": {
    "@type": "ServiceChannel",
    "serviceLocation": {
      "@type": "Place",
      "name": "{{global.brandName}}",
      "address": "{{global.location}}"
    }
  },
  "sameAs": ["{{global.igUrl}}"]
}
</script>

{{> footer}}
</body>
</html>
