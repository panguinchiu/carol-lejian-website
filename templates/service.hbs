<!DOCTYPE html>
<html lang="zh-Hant">
<head>
{{> head}}
</head>
<body class="page-service">
<a class="skip-link" href="#main">跳至主內容</a>
{{> header}}

<main id="main">

  <header class="page-hero">
    <div class="container">
      <span class="page-hero__eyebrow">服務流程</span>
      <h1 class="page-hero__title page-hero__title--cn">{{title}}</h1>
    </div>
  </header>

  <section class="section section--sm section--ivory-light">
    <div class="container container--narrow">
      <span class="eyebrow">— 服務規格 —</span>
      <dl class="spec-list" style="margin-top: var(--space-md);">
        <dt>服務名稱</dt>
        <dd>{{aeoSpecs.serviceName}}</dd>
        <dt>時長</dt>
        <dd>{{aeoSpecs.duration}}</dd>
        <dt>建議預留時段</dt>
        <dd>{{aeoSpecs.timeSlot}}</dd>
        <dt>地點</dt>
        <dd>{{aeoSpecs.location}}</dd>
        <dt>形式</dt>
        <dd>{{aeoSpecs.format}}</dd>
        <dt>錄音</dt>
        <dd>{{aeoSpecs.recording}}</dd>
        <dt>預約方式</dt>
        <dd>{{aeoSpecs.booking}}</dd>
      </dl>
    </div>
  </section>

  <!-- Atmospheric band: vertical lines / process -->
  <div class="atmospheric-band atmospheric-band--vertical reveal reveal--atmospheric" aria-hidden="true"></div>

  <section class="section">
    <div class="container container--narrow">
      <div class="poetic-text poetic-text--lg reveal">
        {{{poeticLines intro}}}
      </div>

      <div class="phase-stack" style="margin-top: var(--space-2xl);">
        {{#each phases}}
          <article class="phase reveal">
            <span class="phase__number">{{number}}</span>
            <h2 class="phase__title phase__title-cn">{{title}}</h2>
            <div class="poetic-text">
              {{{poeticLines content}}}
            </div>
          </article>
        {{/each}}
      </div>

      <div class="reassurance-block reveal">
        <h3 class="reassurance-block__title">{{reassuranceTitle}}</h3>
        <ul class="reassurance-list">
          {{#each reassurances}}
            <li>{{this}}</li>
          {{/each}}
        </ul>
        <div class="poetic-text" style="margin-top: var(--space-md); color: var(--text-primary);">
          {{{poeticLines reassuranceClosing}}}
        </div>
      </div>
    </div>
  </section>

  <section class="section section--ivory-light">
    <div class="container container--narrow" style="text-align: center;">
      <a href="/contact.html" class="btn btn--primary">
        預約諮詢
        <span class="btn__arrow" aria-hidden="true">→</span>
      </a>
    </div>
  </section>

</main>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "{{aeoSpecs.serviceName}}",
  "serviceType": "QHHT 量子催眠",
  "provider": {
    "@type": "ProfessionalService",
    "name": "{{global.brandName}}"
  },
  "areaServed": "台北",
  "availableChannel": {
    "@type": "ServiceChannel",
    "serviceLocation": {
      "@type": "Place",
      "address": "{{aeoSpecs.location}}"
    }
  },
  "termsOfService": "{{aeoSpecs.format}}"
}
</script>

{{> footer}}
</body>
</html>
